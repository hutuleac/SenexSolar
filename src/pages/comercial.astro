---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/layout/WhatsAppButton.astro';
import Calculator from '../components/sections/Calculator.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
import PartnerLogos from '../components/sections/PartnerLogos.astro';
---

<BaseLayout
  title="Sisteme Fotovoltaice Comerciale Iași"
  description="Panouri solare pentru firme, hale industriale și spații comerciale în Iași. Deductibil fiscal, ROI în 3–5 ani. Proiect tehnic gratuit."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container page-hero-content">
        <span class="eyebrow">Comercial</span>
        <h1 class="page-h1 font-display">
          Reduce costurile energetice<br />
          <span class="accent">ale firmei tale cu 70%.</span>
        </h1>
        <p class="page-sub">
          Sisteme fotovoltaice pentru firme, hale industriale, depozite, restaurante și spații
          comerciale. ROI calculabil, 100% deductibil fiscal.
        </p>
        <div class="hero-ctas">
          <a href="/cerere-oferta" class="cta-primary">Solicită studiu de fezabilitate gratuit</a>
          <a href="#calculator" class="cta-secondary">Calculator ROI</a>
        </div>
        <div class="specs-row">
          <span>20–500 kWp</span>
          <span>·</span>
          <span>ROI 3–5 ani</span>
          <span>·</span>
          <span>100% deductibil fiscal</span>
          <span>·</span>
          <span>Monitorizare 24/7</span>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="section">
      <div class="container">
        <div class="benefits-grid animate-on-scroll">
          {[
            { icon: '📉', title: 'Reducere costuri operaționale', desc: 'Un sistem de 50 kWp poate economisi 55.000–70.000 RON/an. Factura electrică este unul dintre cele mai mari costuri fixe ale unei firme.' },
            { icon: '🧾', title: 'Deductibil fiscal 100%', desc: 'Investiția se poate deprecia accelerat — amortizarea fiscală în primii ani reduce impozitul pe profit. Consultați-vă cu contabilul.' },
            { icon: '📊', title: 'ROI predictibil și garantat', desc: 'Cu tariful actual de energie, recuperarea investiției se produce în 3–5 ani. Ulterior, 20+ ani de energie la cost zero.' },
            { icon: '🔧', title: 'Monitorizare și mentenanță', desc: 'Sistem de monitorizare în timp real, alertă automată la defecțiuni. Contract de mentenanță opțional cu intervenție în 24h.' },
          ].map(b => (
            <div class="benefit-card animate-on-scroll">
              <span class="benefit-icon">{b.icon}</span>
              <h3 class="benefit-title">{b.title}</h3>
              <p class="benefit-desc">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Case study comercial -->
    <section class="section case-section">
      <div class="container">
        <div class="case-grid animate-on-scroll">
          <div>
            <span class="eyebrow-green">Studiu de caz</span>
            <h2 class="section-title font-display">SC Tehno Construct SRL, Iași</h2>
            <p class="section-text">
              Hală industrială cu consum de 3.000 RON/lună. După instalarea unui sistem de 20 kWp,
              factura a scăzut la 400 RON. ROI realizat în mai puțin de 4 ani.
            </p>
            <blockquote class="case-quote">
              "Cea mai bună decizie financiară pe care am luat-o pentru firmă.
              Recomand oricărei firme să analizeze această investiție."
              <footer>— Mihai Ionescu, Administrator</footer>
            </blockquote>
          </div>
          <div class="case-stats">
            <div class="case-stat"><span class="cs-num font-display">20 kWp</span><span class="cs-label">Sistem instalat</span></div>
            <div class="case-stat"><span class="cs-num font-display">−87%</span><span class="cs-label">Reducere factură</span></div>
            <div class="case-stat"><span class="cs-num font-display">4 ani</span><span class="cs-label">Recuperare investiție</span></div>
            <div class="case-stat"><span class="cs-num font-display">460K RON</span><span class="cs-label">Economie 25 ani</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section class="section gallery-section">
      <div class="container">
        <h2 class="section-title font-display text-center animate-on-scroll">Instalări comerciale.</h2>
        <div class="gallery-grid animate-on-scroll">
          <img src="/images/Panouri_solare_instalate_pe_structura_metalica_cu_Sine.jpg" alt="Sistem solar structura metalica" width="400" height="300" loading="lazy" class="gallery-img" />
          <img src="/images/Panouri_solare_instalate_pe_structura_metalica_mobila.jpg" alt="Sistem solar structura mobila" width="400" height="300" loading="lazy" class="gallery-img" />
          <img src="/images/Panouri_solare_instalate_pe_sol.jpg" alt="Panouri solare pe sol" width="400" height="300" loading="lazy" class="gallery-img" />
          <img src="/images/Panouri_solare_instalate_pe_stalp.jpg" alt="Panouri solare pe stalp" width="400" height="300" loading="lazy" class="gallery-img" />
        </div>
      </div>
    </section>

    <Calculator />
    <PartnerLogos />
    <ContactCTA />
  </main>
  <Footer />
  <WhatsAppButton />
</BaseLayout>

<style>
  .page-hero {
    background: #1A1A1A;
    padding-block: 5rem 4rem;
  }

  .page-hero-content { max-width: 720px; }

  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }

  .eyebrow-green {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #1E6B3A;
    margin-bottom: 0.75rem;
  }

  .page-h1 {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .accent { color: #F5A623; }

  .page-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    margin-bottom: 2rem;
    max-width: 580px;
  }

  .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.75rem; }

  .cta-primary {
    display: inline-flex;
    background: #F5A623;
    color: #1A1A1A;
    font-weight: 700;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    transition: background 0.15s, transform 0.15s;
  }

  .cta-primary:hover { background: #d4891a; transform: translateY(-2px); }

  .cta-secondary {
    display: inline-flex;
    background: rgba(255,255,255,0.1);
    color: white;
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    transition: background 0.15s;
  }

  .cta-secondary:hover { background: rgba(255,255,255,0.18); }

  .specs-row { display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 0.875rem; color: rgba(255,255,255,0.5); }

  .section { padding-block: 5rem; }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: #1A1A1A;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin-bottom: 1rem;
  }

  .text-center { text-align: center; }

  .section-text { color: #4A4A4A; line-height: 1.7; margin-bottom: 1.25rem; }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .benefits-grid { grid-template-columns: repeat(4, 1fr); } }

  .benefit-card {
    background: #F7F6F2;
    border-radius: 12px;
    padding: 1.75rem;
    border: 1px solid #E2E0D8;
  }

  .benefit-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .benefit-title { font-size: 1rem; font-weight: 700; color: #1A1A1A; margin-bottom: 0.5rem; }
  .benefit-desc { font-size: 0.875rem; color: #6B6B6B; line-height: 1.6; }

  .case-section { background: #F7F6F2; }

  .case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) { .case-grid { grid-template-columns: 1fr 1fr; align-items: center; } }

  .case-quote {
    font-style: italic;
    color: #4A4A4A;
    font-size: 0.95rem;
    border-left: 3px solid #F5A623;
    padding-left: 1rem;
    margin: 1.5rem 0 0;
    line-height: 1.65;
  }

  .case-quote footer { font-style: normal; font-weight: 600; color: #1E6B3A; font-size: 0.85rem; margin-top: 0.5rem; }

  .case-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .case-stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .cs-num { font-size: 2rem; color: #1E6B3A; line-height: 1; letter-spacing: -0.02em; }
  .cs-label { font-size: 0.78rem; color: #6B6B6B; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }

  .gallery-section { background: white; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) { .gallery-grid { grid-template-columns: repeat(4, 1fr); } }

  .gallery-img { width: 100%; height: 220px; object-fit: cover; border-radius: 8px; }
</style>
