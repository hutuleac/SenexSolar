---
const services = [
  {
    icon: '🏠',
    title: 'Sistem Fotovoltaic Rezidențial',
    description: 'Pentru case unifamiliale și vile din Iași și Moldova.',
    specs: ['5–15 kWp putere instalată', 'Recuperare investiție 5–7 ani', 'Finanțare în rate prin TBI Bank'],
    href: '/rezidential',
    accent: true,
  },
  {
    icon: '🏭',
    title: 'Sistem Fotovoltaic Comercial',
    description: 'Pentru firme, hale industriale și spații comerciale.',
    specs: ['20–500 kWp putere instalată', 'Deductibil fiscal 100%', 'ROI în 3–5 ani'],
    href: '/comercial',
    accent: false,
  },
  {
    icon: '🔋',
    title: 'Stocare Energie (Baterii)',
    description: 'Independență totală de rețea. Stocare noaptea, consum ziua.',
    specs: ['Compatibil cu orice sistem solar', 'Protecție la pene de curent', 'Monitorizare app mobilă'],
    href: '/rezidential#baterii',
    accent: false,
  },
];
---

<section class="section services-section" id="servicii">
  <div class="container">
    <div class="services-header animate-on-scroll">
      <span class="section-eyebrow">Servicii</span>
      <h2 class="section-title font-display">
        Soluții pentru orice nevoie energetică.
      </h2>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <div class={`service-card animate-on-scroll ${service.accent ? 'featured' : ''}`} style={`animation-delay: ${i * 0.1}s`}>
          <div class="service-icon">{service.icon}</div>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.description}</p>
          <ul class="service-specs">
            {service.specs.map((spec) => (
              <li class="service-spec">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                {spec}
              </li>
            ))}
          </ul>
          <a href={service.href} class={`service-link ${service.accent ? 'service-link-featured' : ''}`}>
            Află mai multe
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: white;
  }

  .services-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #1E6B3A;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 400;
    color: #1A1A1A;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    background: #F7F6F2;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid #E2E0D8;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(30,107,58,0.1);
  }

  .service-card.featured {
    background: #1E6B3A;
    border-color: #1E6B3A;
    color: white;
  }

  .service-icon {
    font-size: 2rem;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1A1A1A;
  }

  .featured .service-title {
    color: white;
  }

  .service-desc {
    font-size: 0.9rem;
    color: #6B6B6B;
    line-height: 1.6;
  }

  .featured .service-desc {
    color: rgba(255,255,255,0.75);
  }

  .service-specs {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-spec {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: #4A4A4A;
  }

  .featured .service-spec {
    color: rgba(255,255,255,0.88);
  }

  .featured .service-spec svg {
    color: #F5A623;
  }

  .service-spec svg {
    color: #1E6B3A;
    flex-shrink: 0;
  }

  .service-link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1E6B3A;
    transition: gap 0.15s;
  }

  .service-link:hover {
    gap: 0.6rem;
  }

  .service-link-featured {
    color: #F5A623;
  }
</style>
