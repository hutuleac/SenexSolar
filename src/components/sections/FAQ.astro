---
import { FAQAccordion, faqs } from '../islands/FAQAccordion';
import { getFAQSchema } from '../../lib/schema';

const faqSchema = getFAQSchema(faqs);
---

<section class="section faq-section" id="intrebari-frecvente">
  <div class="container faq-inner">
    <div class="faq-header animate-on-scroll">
      <span class="section-eyebrow">FAQ</span>
      <h2 class="section-title font-display">
        Întrebări frecvente.
      </h2>
      <p class="section-sub">
        Nu găsești răspunsul? Sună-ne sau trimite un mesaj — răspundem în 24h.
      </p>
    </div>

    <div class="faq-content animate-on-scroll">
      <FAQAccordion client:visible />
    </div>
  </div>
</section>

<!-- FAQPage JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-section {
    background: white;
  }

  .faq-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .faq-inner {
      grid-template-columns: 1fr 2fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .faq-header {
    position: sticky;
    top: 100px;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #1E6B3A;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 400;
    color: #1A1A1A;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.015em;
  }

  .section-sub {
    color: #6B6B6B;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .faq-content {
    max-width: 720px;
  }
</style>
