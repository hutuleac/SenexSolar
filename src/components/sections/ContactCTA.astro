---
import { SITE } from '../../lib/constants';
import { ContactForm } from '../islands/ContactForm';
---

<section class="section contact-section" id="contact">
  <div class="container contact-grid">
    <!-- Left: Text + alternatives -->
    <div class="contact-info animate-on-scroll">
      <span class="section-eyebrow">Contact</span>
      <h2 class="contact-title font-display">
        Fă primul pas.<br />
        <span class="title-accent">E gratuit și fără obligații.</span>
      </h2>

      <p class="contact-text">
        Nu îți cerem să cumperi nimic acum. Trimite-ne factura ta la curent și îți facem
        o analiză completă cu cât ai economisi și ce finanțare poți accesa.
      </p>

      <div class="contact-guarantee">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#1E6B3A" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        100% gratuit.
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#1E6B3A" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        Fără spam.
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#1E6B3A" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        Fără apeluri repetate.
      </div>

      <div class="contact-alternatives">
        <a href={SITE.phoneHref} class="contact-alt-item">
          <div class="alt-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
          </div>
          <div>
            <span class="alt-label">Sună direct</span>
            <span class="alt-value">{SITE.phone}</span>
          </div>
        </a>

        <a href={SITE.whatsapp} class="contact-alt-item" target="_blank" rel="noopener noreferrer">
          <div class="alt-icon whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <span class="alt-label">WhatsApp</span>
            <span class="alt-value">{SITE.phone}</span>
          </div>
        </a>

        <a href={`mailto:${SITE.email}`} class="contact-alt-item">
          <div class="alt-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <div>
            <span class="alt-label">Email</span>
            <span class="alt-value">{SITE.email}</span>
          </div>
        </a>

        <div class="contact-alt-item no-link">
          <div class="alt-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <div>
            <span class="alt-label">Adresă</span>
            <span class="alt-value" style="font-size: 0.8rem">{SITE.address}</span>
          </div>
        </div>
      </div>

      <div class="contact-hours">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
        </svg>
        {SITE.hours}
      </div>
    </div>

    <!-- Right: Form -->
    <div class="contact-form-col animate-on-scroll">
      <div class="form-card">
        <h3 class="form-card-title">Solicită analiza gratuită</h3>
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: #F7F6F2;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #1E6B3A;
    margin-bottom: 0.75rem;
  }

  .contact-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: #1A1A1A;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.015em;
  }

  .title-accent { color: #1E6B3A; }

  .contact-text {
    color: #4A4A4A;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .contact-guarantee {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #1E6B3A;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .contact-alternatives {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .contact-alt-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem;
    background: white;
    border-radius: 8px;
    border: 1px solid #E2E0D8;
    transition: border-color 0.15s, box-shadow 0.15s;
    text-decoration: none;
  }

  .contact-alt-item:not(.no-link):hover {
    border-color: #1E6B3A;
    box-shadow: 0 2px 12px rgba(30,107,58,0.1);
  }

  .alt-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(30,107,58,0.08);
    color: #1E6B3A;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .alt-icon.whatsapp {
    background: rgba(37,211,102,0.1);
    color: #25d366;
  }

  .alt-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9B9B9B;
    margin-bottom: 0.1rem;
  }

  .alt-value {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: #1A1A1A;
  }

  .contact-hours {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #9B9B9B;
  }

  .form-card {
    background: white;
    border-radius: 16px;
    padding: 2.5rem;
    border: 1px solid #E2E0D8;
    box-shadow: 0 4px 32px rgba(30,107,58,0.06);
  }

  @media (max-width: 640px) {
    .form-card { padding: 1.5rem; }
  }

  .form-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 1.5rem;
  }
</style>
