---
const partners = [
  { name: 'Canadian Solar', category: 'Panouri' },
  { name: 'Trina Solar', category: 'Panouri' },
  { name: 'JA Solar', category: 'Panouri' },
  { name: 'Fronius', category: 'Invertoare' },
  { name: 'SMA', category: 'Invertoare' },
  { name: 'Huawei FusionSolar', category: 'Invertoare' },
  { name: 'SolarEdge', category: 'Invertoare' },
  { name: 'BYD', category: 'Baterii' },
  { name: 'Pylontech', category: 'Baterii' },
  { name: 'RPIA', category: 'Asociație' },
];
---

<section class="partners-section" aria-label="Parteneri și echipamente">
  <div class="container partners-header animate-on-scroll">
    <p class="partners-label">Lucrăm exclusiv cu producători de top</p>
  </div>

  <div class="marquee-container" aria-hidden="true">
    <div class="marquee-track">
      {[...partners, ...partners].map((p, i) => (
        <div class="partner-chip" key={i}>
          <span class="partner-category">{p.category}</span>
          <span class="partner-name">{p.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partners-section {
    background: white;
    padding-block: 3rem;
    border-top: 1px solid #E2E0D8;
    border-bottom: 1px solid #E2E0D8;
    overflow: hidden;
  }

  .partners-header {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .partners-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #9B9B9B;
  }

  .marquee-container {
    overflow: hidden;
    width: 100%;
  }

  .partner-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    background: #F7F6F2;
    border: 1px solid #E2E0D8;
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    min-width: 140px;
    margin-right: 1rem;
  }

  .partner-category {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1E6B3A;
  }

  .partner-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #1A1A1A;
    white-space: nowrap;
  }
</style>
