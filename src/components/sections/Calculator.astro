---
import { SavingsCalculator } from '../islands/SavingsCalculator';
---

<section class="section calc-section" id="calculator">
  <div class="container">
    <div class="calc-header animate-on-scroll">
      <span class="section-eyebrow">Calculator economii</span>
      <h2 class="section-title font-display">
        Cât ai economisi<br />pe factura ta?
      </h2>
      <p class="section-sub">
        Ajustează valorile de mai jos și vezi instant cât ar produce un sistem solar
        dimensionat pentru consumul tău.
      </p>
    </div>

    <div class="calc-card animate-on-scroll">
      <SavingsCalculator client:visible />
    </div>

    <p class="calc-disclaimer">
      * Calculul este orientativ. Valoarea exactă depinde de orientarea acoperișului,
      umbrire și tipul sistemului. Oferta personalizată gratuită include o analiză precisă.
    </p>
  </div>
</section>

<style>
  .calc-section {
    background: #F7F6F2;
  }

  .calc-header {
    text-align: center;
    max-width: 580px;
    margin: 0 auto 2.5rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #1E6B3A;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 400;
    color: #1A1A1A;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.015em;
  }

  .section-sub {
    color: #6B6B6B;
    font-size: 1rem;
    line-height: 1.65;
  }

  .calc-card {
    background: white;
    border-radius: 16px;
    padding: 2.5rem;
    max-width: 820px;
    margin: 0 auto;
    box-shadow: 0 4px 32px rgba(30,107,58,0.08), 0 1px 4px rgba(0,0,0,0.06);
    border: 1px solid #E2E0D8;
  }

  @media (max-width: 640px) {
    .calc-card {
      padding: 1.5rem;
    }
  }

  .calc-disclaimer {
    text-align: center;
    font-size: 0.8rem;
    color: #9B9B9B;
    margin-top: 1.25rem;
    max-width: 600px;
    margin-inline: auto;
  }

  /* Calculator island styles — scoped via global to reach React component */
  :global(.calc-wrapper) {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    :global(.calc-wrapper) {
      flex-direction: row;
      gap: 2.5rem;
      align-items: flex-start;
    }
  }

  :global(.calc-inputs) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.calc-field) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.calc-label) {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1A1A1A;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  :global(.calc-bill-val) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1E6B3A;
  }

  :global(.calc-slider) {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(to right, #1E6B3A 0%, #1E6B3A var(--pct, 14%), #E2E0D8 var(--pct, 14%), #E2E0D8 100%);
    cursor: pointer;
    outline: none;
  }

  :global(.calc-slider::-webkit-slider-thumb) {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #1E6B3A;
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 2px 6px rgba(30,107,58,0.35);
  }

  :global(.calc-slider-labels) {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: #9B9B9B;
  }

  :global(.calc-toggle) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  :global(.calc-toggle-btn) {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: 2px solid #E2E0D8;
    background: transparent;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    color: #6B6B6B;
    font-family: inherit;
  }

  :global(.calc-toggle-btn.active) {
    border-color: #1E6B3A;
    background: rgba(30,107,58,0.08);
    color: #1E6B3A;
  }

  :global(.calc-select) {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: 2px solid #E2E0D8;
    background: white;
    font-size: 0.875rem;
    color: #1A1A1A;
    cursor: pointer;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  :global(.calc-select:focus) {
    border-color: #1E6B3A;
  }

  :global(.calc-results) {
    flex: 1;
    background: #F7F6F2;
    border-radius: 12px;
    padding: 1.75rem;
    border: 1px solid #E2E0D8;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  :global(.calc-result-header) {
    border-bottom: 1px solid #E2E0D8;
    padding-bottom: 1rem;
  }

  :global(.calc-system-badge) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1E6B3A;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  :global(.calc-metrics) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  :global(.calc-metric) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.calc-metric.primary .calc-metric-val) {
    font-size: 1.5rem;
    color: #1E6B3A;
  }

  :global(.calc-metric-val) {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: #1A1A1A;
    line-height: 1.1;
  }

  :global(.calc-metric-label) {
    font-size: 0.75rem;
    color: #6B6B6B;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  :global(.calc-grant-note) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: #1E6B3A;
    background: rgba(30,107,58,0.08);
    padding: 0.6rem 0.875rem;
    border-radius: 6px;
  }

  :global(.calc-co2) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #6B6B6B;
  }

  :global(.calc-cta) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: #F5A623;
    color: #1A1A1A;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.875rem 1.25rem;
    border-radius: 8px;
    text-align: center;
    transition: background 0.15s, transform 0.15s;
    text-decoration: none;
  }

  :global(.calc-cta:hover) {
    background: #d4891a;
    transform: translateY(-2px);
  }
</style>
