---
import { SITE } from '../../lib/constants';
---

<section class="hero" id="acasa" aria-label="Hero — Senex Solar Power">
  <!-- Background video -->
  <video
    class="hero-video"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    poster="/images/Panouri_solare_instalate_pe_casa.webp"
    aria-hidden="true"
  >
    <source src="/videos/Hero_video.mp4" type="video/mp4" />
  </video>

  <!-- Overlay -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="container hero-content">
    <div class="hero-text animate-fade-in">
      <h1 class="hero-h1 font-display">
        Factura la curent<br />
        <span class="hero-h1-accent">la zero.</span><br />
        Instalat în Iași,<br />
        garantat 25 de ani.
      </h1>

      <p class="hero-sub animate-fade-in-delay">
        Proiectăm, instalăm și întreținem sisteme fotovoltaice<br class="hidden-mobile" />
        pentru case și afaceri din Moldova. Fără bătăi de cap,<br class="hidden-mobile" />
        fără surprize la factură.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas animate-fade-in-delay-2">
        <a href="#calculator" class="hero-cta-primary">
          Calculează cât economisești
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
          </svg>
        </a>
        <a href={SITE.phoneHref} class="hero-cta-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Sună acum: {SITE.phone}
        </a>
      </div>

      <!-- Trust badges -->
      <div class="trust-badges animate-fade-in-delay-2">
        <span class="trust-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Autorizat ANRE
        </span>
        <span class="trust-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Partener Casa Verde
        </span>
        <span class="trust-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          150+ instalații în Moldova
        </span>
        <span class="trust-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Garanție 25 ani
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #0a1f10;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.68) 0%, rgba(10,40,20,0.55) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: 6rem 4rem;
  }

  .hero-text {
    max-width: 680px;
  }

  .hero-h1 {
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-h1-accent {
    color: #F5A623;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.82);
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .hidden-mobile {
    display: none;
  }

  @media (min-width: 640px) {
    .hidden-mobile { display: inline; }
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #F5A623;
    color: #1A1A1A;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    transition: background 0.15s, transform 0.15s;
  }

  .hero-cta-primary:hover {
    background: #d4891a;
    transform: translateY(-2px);
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.12);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(4px);
    transition: background 0.15s, transform 0.15s;
  }

  .hero-cta-secondary:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-2px);
  }

  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.88);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: 50px;
    border: 1px solid rgba(255,255,255,0.15);
    backdrop-filter: blur(4px);
  }
</style>
