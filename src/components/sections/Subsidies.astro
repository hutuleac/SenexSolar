---
---

<section class="section subsidies-section" id="subventii">
  <div class="container subsidies-grid">
    <!-- Text content -->
    <div class="subsidies-content animate-on-scroll">
      <span class="section-eyebrow light">Program AFM 2025</span>
      <h2 class="subsidies-title font-display">
        20.000 RON grant<br />de la stat.<br />
        <span class="title-accent">Te ajutăm să îl iei.</span>
      </h2>

      <p class="subsidies-text">
        Programul Casa Verde Fotovoltaice — Administrația Fondului pentru Mediu — acordă
        finanțare nerambursabilă de până la <strong>20.000 RON</strong> pentru instalarea unui sistem
        fotovoltaic la casa ta. Bani pe care <em>nu trebuie să îi returnezi.</em>
      </p>

      <ul class="subsidies-checks">
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Nu trebuie să returnezi banii
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Ne ocupăm noi de toată documentația
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Acceptat și pentru case nou construite
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Te ghidăm pas cu pas prin proces
        </li>
      </ul>

      <a href="/subventii-casa-verde" class="subsidies-cta">
        Descarcă Ghidul Complet AFM — Gratuit
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
        </svg>
      </a>
      <p class="subsidies-note">PDF 8 pagini · Ghid complet, pas cu pas</p>
    </div>

    <!-- Conditions box -->
    <div class="subsidies-box animate-on-scroll">
      <h3 class="subsidies-box-title">Condiții principale</h3>
      <ul class="subsidies-conditions">
        <li>
          <span class="cond-icon">🏠</span>
          <div>
            <strong>Proprietar persoană fizică</strong>
            <p>Casa trebuie să fie înregistrată pe numele tău</p>
          </div>
        </li>
        <li>
          <span class="cond-icon">🏡</span>
          <div>
            <strong>Casă unifamilială</strong>
            <p>Nu se aplică pentru apartamente la bloc</p>
          </div>
        </li>
        <li>
          <span class="cond-icon">📋</span>
          <div>
            <strong>Fără finanțare AFM anterioară</strong>
            <p>Programul este pentru beneficiari noi</p>
          </div>
        </li>
        <li>
          <span class="cond-icon">⚡</span>
          <div>
            <strong>Sistem minim 3 kWp</strong>
            <p>Valoarea finanțată depinde de puterea instalată</p>
          </div>
        </li>
      </ul>

      <a href="/subventii-casa-verde#verificare" class="subsidies-check-btn">
        Verifică dacă te califici
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .subsidies-section {
    background: #1E6B3A;
    color: white;
  }

  .subsidies-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .subsidies-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }

  .section-eyebrow.light {
    color: rgba(255,255,255,0.6);
  }

  .subsidies-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .title-accent {
    color: #F5A623;
  }

  .subsidies-text {
    color: rgba(255,255,255,0.82);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .subsidies-checks {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .subsidies-checks li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.9);
    font-weight: 500;
  }

  .subsidies-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #F5A623;
    color: #1A1A1A;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    transition: background 0.15s, transform 0.15s;
  }

  .subsidies-cta:hover {
    background: #d4891a;
    transform: translateY(-2px);
  }

  .subsidies-note {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    margin-top: 0.5rem;
  }

  .subsidies-box {
    background: rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid rgba(255,255,255,0.15);
  }

  .subsidies-box-title {
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
  }

  .subsidies-conditions {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .subsidies-conditions li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .cond-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .subsidies-conditions strong {
    display: block;
    font-size: 0.9rem;
    color: white;
    margin-bottom: 0.2rem;
  }

  .subsidies-conditions p {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  .subsidies-check-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    background: rgba(255,255,255,0.12);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    transition: background 0.15s;
  }

  .subsidies-check-btn:hover {
    background: rgba(255,255,255,0.2);
  }
</style>
