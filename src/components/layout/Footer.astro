---
import { SITE, NAV_LINKS } from '../../lib/constants';
---

<footer class="footer">
  <div class="container footer-inner">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" aria-label="Senex Solar Power">
        <img src="/logo.svg" alt="Senex Solar Power" width="160" height="36" />
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>
      <p class="footer-address">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0;margin-top:2px">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        {SITE.address}
      </p>
      <p class="footer-hours">{SITE.hours}</p>
    </div>

    <!-- Nav -->
    <div class="footer-nav">
      <h3 class="footer-heading">Servicii</h3>
      <nav>
        {NAV_LINKS.map((link) => (
          <a href={link.href} class="footer-link">{link.label}</a>
        ))}
        <a href="/cerere-oferta" class="footer-link">Cerere Ofertă</a>
      </nav>
    </div>

    <!-- Contact -->
    <div class="footer-contact">
      <h3 class="footer-heading">Contact</h3>
      <a href={SITE.phoneHref} class="footer-link footer-contact-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        {SITE.phone}
      </a>
      <a href={`mailto:${SITE.email}`} class="footer-link footer-contact-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
        Email
      </a>
      <a href={SITE.whatsapp} class="footer-link footer-contact-item" target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <!-- Badges -->
    <div class="footer-badges">
      <h3 class="footer-heading">Certificări</h3>
      <div class="badge-list">
        <span class="footer-badge">✓ Autorizat ANRE</span>
        <span class="footer-badge">✓ Partener Casa Verde AFM</span>
        <span class="footer-badge">✓ 25 ani garanție</span>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {new Date().getFullYear()} {SITE.name}. Toate drepturile rezervate.</p>
      <div class="footer-legal">
        <a href="/politica-confidentialitate" class="footer-legal-link">Politică Confidențialitate</a>
        <a href="/termeni-conditii" class="footer-legal-link">Termeni și Condiții</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1A1A1A;
    color: rgba(255,255,255,0.75);
    margin-top: 0;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: 3.5rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    font-style: italic;
  }

  .footer-address {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    line-height: 1.5;
  }

  .footer-hours {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
  }

  .footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1rem;
  }

  nav { display: flex; flex-direction: column; gap: 0.4rem; }

  .footer-link {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    transition: color 0.15s;
    padding: 0.2rem 0;
  }

  .footer-link:hover { color: #fff; }

  .footer-contact { display: flex; flex-direction: column; gap: 0.5rem; }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .footer-badge {
    font-size: 0.8rem;
    color: rgba(245,166,35,0.9);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: 1.25rem;
  }

  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8rem;
  }

  .footer-legal { display: flex; gap: 1.5rem; }

  .footer-legal-link {
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
    transition: color 0.15s;
  }

  .footer-legal-link:hover { color: rgba(255,255,255,0.7); }
</style>
