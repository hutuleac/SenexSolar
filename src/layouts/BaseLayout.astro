---
import { SITE } from '../lib/constants';
import { getLocalBusinessSchema, getOrganizationSchema } from '../lib/schema';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: object | object[];
  noindex?: boolean;
  publishDate?: Date;
}

const {
  title,
  description = 'Instalare panouri fotovoltaice în Iași și Moldova. Sisteme rezidențiale și comerciale, finanțare în rate TBI Bank. Analiză gratuită, garanție 25 ani.',
  image = SITE.og.image,
  schema,
  noindex = false,
  publishDate,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const ogImage = new URL(image, SITE.url);

const localBusinessSchema = getLocalBusinessSchema();
const organizationSchema = getOrganizationSchema();
const schemas = [
  localBusinessSchema,
  organizationSchema,
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(SITE.og.width)} />
    <meta property="og:image:height" content={String(SITE.og.height)} />
    <meta property="og:locale" content="ro_RO" />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Article dates (blog posts) -->
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {publishDate && <meta property="article:modified_time" content={publishDate.toISOString()} />}
    {publishDate && <meta property="og:type" content="article" />}

    <!-- hreflang -->
    <link rel="alternate" hreflang="ro" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="j6BWnHxM1NI1A_AO5ep3Rwyu2jCe-vH4d7rysEculNE" />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-518ZZEKMDQ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-518ZZEKMDQ');

      // Track all phone (tel:) link clicks
      document.addEventListener('click', function(e) {
        var el = e.target.closest('a[href^="tel:"]');
        if (el) {
          gtag('event', 'phone_click', { event_category: 'contact', event_label: el.href });
        }
      });

      // Track WhatsApp button clicks
      document.addEventListener('click', function(e) {
        if (e.target.closest('[data-track="whatsapp_click"]')) {
          gtag('event', 'whatsapp_click', { event_category: 'contact' });
        }
      });
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- JSON-LD Schemas -->
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
